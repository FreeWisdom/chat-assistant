# ============================================
# AI 助教机器人 - 环境配置
# ============================================

# DeepSeek API
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 机器人行为
BOT_NAME=AI助教
COOLDOWN_SECONDS=30
MAX_REPLY_LENGTH=500
REPLY_DELAY_MIN=1.0
REPLY_DELAY_MAX=4.0
POLL_INTERVAL=12
POLL_LOAD_WAIT=3
CHAT_SEARCH_TIMEOUT=5
FORCE_SWITCH_EACH_POLL=false
DEV_MODE=false
# ⚠️ 首次启动建议 DRY_RUN=true，只读消息生成回答但 不真发送 到群
DRY_RUN=true
# 指定后只监听这一个群（忽略 bindings 中的其他群）；留空监听全部
TEST_GROUP=

# 知识库检索
KNOWLEDGE_CHUNK_SIZE=500
KNOWLEDGE_CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5

# 本地向量库。首次启用会下载 EMBEDDING_MODEL 到本机缓存。
VECTOR_SEARCH_ENABLED=true
VECTOR_DB_DIR=./vector_store/chroma
INDEX_MANIFEST_PATH=./vector_store/index_manifest.json
CHROMA_COLLECTION_NAME=ai_ta_bot_knowledge
CHROMA_BATCH_SIZE=64
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# 网页知识库
WEB_FETCH_TIMEOUT=12
WEB_MAX_PAGES_PER_KB=50
WEB_USER_AGENT=ai-ta-bot/0.1 (+local knowledge connector)

# 本地管理/平台同步服务
# 平台同步时建议填写随机 token，并在请求头 X-Admin-Token 中携带。
ADMIN_SYNC_TOKEN=
# 如果平台前端要直接同步到本机，把平台域名加入这里，例如 https://your-platform.example.com
ADMIN_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
