# ============================================
# AI 助教机器人 - 环境配置
# ============================================

# DeepSeek API
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 机器人行为
BOT_NAME=AI助教
COOLDOWN_SECONDS=30
MAX_REPLY_LENGTH=500
POLL_INTERVAL=12
POLL_LOAD_WAIT=3
CHAT_SEARCH_TIMEOUT=5
FORCE_SWITCH_EACH_POLL=false
DEV_MODE=false
