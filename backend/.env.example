# ============================================
# AI 助教机器人 - 环境配置
# ============================================

# DeepSeek API
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30

# 微信任务处理
CHAT_SEARCH_TIMEOUT=5
TASK_WORKER_INTERVAL=0.5
# 不同群可并行调用知识库/搜索/大模型；同一群仍按消息顺序处理
GROUP_WORKER_COUNT=4
TASK_MAX_ATTEMPTS=3
TASK_RETRY_BASE_SECONDS=5
TASK_RETRY_MAX_SECONDS=60
# 发送后在群窗口中读回相同文本，确认消息确实出现
SEND_VERIFY_TIMEOUT=5
SEND_VERIFY_INTERVAL=0.5
DEV_MODE=false
# ⚠️ 首次启动建议 DRY_RUN=true，只读消息生成回答但 不真发送 到群
DRY_RUN=true
# 必须显式改成 true 后，才允许 DRY_RUN=false 的真实发送模式启动。
ALLOW_REAL_SEND_CONFIRM=false
# 显式群白名单，多个群使用英文逗号分隔；只会监听同时存在于 bindings 的群
LISTEN_GROUPS=项目研究,每日饮食打卡🍽️
# 本账号在群内可能显示的昵称/群昵称，用于识别 @机器人 和引用机器人消息
# 多个昵称使用英文逗号分隔；不要填写其他群成员昵称
BOT_MENTION_NAMES=your_wechat_nickname
# 兼容旧版单群配置；LISTEN_GROUPS 非空时忽略此项
TEST_GROUP=
# 默认要求显式设置群白名单，避免误监听/误发送到其他群
REQUIRE_LISTEN_GROUPS=true

# 阿里云百炼云知识库
# AccessKey 只放在环境变量，不写入 config/bot.yaml。
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com
# 平台统一使用的业务空间，只在服务端配置，不返回给用户浏览器。
ALIYUN_BAILIAN_WORKSPACE_ID=your_aliyun_workspace_id

# MaxKB 本地应用 + 云端模型 API（provider=maxkb 时使用）
# 在 MaxKB 中配置云端模型供应商、知识库和应用；本项目只保存应用 API Key 和 App ID。
MAXKB_BASE_URL=http://127.0.0.1:8080
MAXKB_API_KEY=your_maxkb_api_key
MAXKB_CHAT_PATH=/chat/api
MAXKB_TIMEOUT_SECONDS=60

RETRIEVAL_TOP_K=5
KNOWLEDGE_RETRIEVAL_MIN_SCORE=0.2
KNOWLEDGE_RETRIEVAL_TIMEOUT_SECONDS=20
KNOWLEDGE_RETRIEVAL_MAX_ATTEMPTS=2
# 页面单次最多上传 10 个文件；单文件最大 100MB。

# SQLite 运行状态（任务去重 + 用户历史）
BOT_STATE_DB=runtime/bot_state.db
BOT_LOCK_FILE=runtime/bot.lock
BOT_HEALTH_PATH=runtime/bot_health.json

# 实时联网搜索：由 LLM 路由器判定为时效/外部事实，或知识库未命中时调用。
# 支持两种后端: "volcengine"（火山引擎，中文好）和 "tavily"（英文为主）
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=volcengine
WEB_SEARCH_TIMEOUT=12
WEB_SEARCH_MAX_RESULTS=5

# Tavily（英文搜索为主，WEB_SEARCH_PROVIDER=tavily 时使用）
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_URL=https://api.tavily.com/search
WEB_SEARCH_DEPTH=advanced

# 火山引擎联网搜索（中文搜索推荐，WEB_SEARCH_PROVIDER=volcengine 时使用）
# API Key 从 https://console.volcengine.com/search-infinity/api-key 获取
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_SEARCH_URL=https://api.volcengine.com/web_search/v1/query
WEB_SEARCH_COUNTRY=china
# 普通搜索查最近一个月、无结果可放宽到一年；时效问题查一天或一周且不放宽
WEB_SEARCH_TIME_RANGE=month
WEB_SEARCH_FRESH_TIME_RANGE=week
WEB_SEARCH_FALLBACK_TIME_RANGE=year

# 本地管理/平台同步服务
# 平台同步时建议填写随机 token，并在请求头 X-Admin-Token 中携带。
ADMIN_SYNC_TOKEN=
# 如果平台前端要直接同步到本机，把平台域名加入这里，例如 https://your-platform.example.com
ADMIN_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
